{
    "version": 1,
    "project": "octave_kernel",
    "project_url": "https://github.com/Calysto/octave_kernel",
    "repo": ".",
    "branches": ["main"],
    "environment_type": "virtualenv",
    "show_commit_url": "https://github.com/Calysto/octave_kernel/commit/",
    "benchmarks_dir": "benchmarks",
    "build_cache_size": 2,
    "build_command": [
        "pip install 'hatchling>=1.25'",
        "pip wheel --no-deps --no-build-isolation -w {build_cache_dir} {build_dir}"
    ],
    "install_command": ["pip install {wheel_file}"]
}
